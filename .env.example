
# Copy this file to .env — NEVER commit .env to GitHub

# ── EmailJS (for email verification) ─────────────────────────────────────────
# 1. Sign up free at https://emailjs.com
# 2. Add a service (Gmail, Outlook, etc.) → copy the Service ID
# 3. Create a template with these variables:
#       {{to_email}}          → recipient address
#       {{to_name}}           → student name
#       {{verification_code}} → the 6-digit code
#    Copy the Template ID
# 4. Account → API Keys → copy your Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ── Firebase (Auth + Firestore) ───────────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Cloudinary (file uploads) ─────────────────────────────────────────────────
# cloudinary.com → Dashboard → Settings → Upload Presets (Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
